# =============================================================================
# PTSD-Ai Environment Configuration
# Copy to .env and fill in your real values. NEVER commit .env to git.
# =============================================================================

# --- LiveKit (voice infrastructure) ---
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- LLM Provider ---
# Options: anthropic | openai | gemma_local | gemma_vertex
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-7

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# OpenAI (GPT-4o)
OPENAI_API_KEY=

# Google AI (Gemma 4 via Vertex AI)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-credentials.json
VERTEX_PROJECT_ID=
VERTEX_REGION=me-west1  # Tel Aviv region for low latency

# Gemma local (self-hosted via vLLM/Ollama)
GEMMA_LOCAL_URL=http://localhost:8001/v1
GEMMA_LOCAL_MODEL=gemma-4-31b-it

# --- STT (Speech-to-Text) ---
# Options: ivrit_ai | openai_whisper | azure
STT_PROVIDER=ivrit_ai
IVRIT_AI_MODEL=ivrit-ai/whisper-large-v3-turbo
# If using OpenAI Whisper API:
# (uses OPENAI_API_KEY above)
# If using Azure:
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=israelcentral

# --- TTS (Text-to-Speech) ---
# Options: elevenlabs | azure | google
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=  # find a Hebrew voice in their library
ELEVENLABS_MODEL=eleven_multilingual_v2

# --- Embeddings (for RAG) ---
# Options: cohere | openai | voyage
EMBEDDING_PROVIDER=cohere
COHERE_API_KEY=
EMBEDDING_MODEL=embed-multilingual-v3.0

# --- Vector DB (Qdrant) ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=ptsd_articles_he

# --- Twilio (phone calls - optional) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+972...
LIVEKIT_SIP_TRUNK_ID=

# --- Safety / Crisis hotlines ---
CRISIS_HOTLINE_ERAN=1201
CRISIS_HOTLINE_NATAL=1-800-363-363
ENABLE_CRISIS_DETECTION=true

# --- Observability ---
LOG_LEVEL=INFO
SENTRY_DSN=

# --- Server ---
HOST=0.0.0.0
PORT=7880
ENVIRONMENT=development  # development | staging | production
